generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model User {
  id        String   @id 
  email     String   @unique
  username  String   @unique
  password  String?  // nullable (for Google users)

  googleId  String?  @unique
  avatar    String?  // profile image

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}